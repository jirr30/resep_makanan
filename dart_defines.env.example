# Salin file ini menjadi dart_defines.env dan isi nilainya.
# JANGAN commit dart_defines.env ke git.

# Gemini API Key — dapatkan di https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Cara build ---
# Debug:
#   flutter run --dart-define=GEMINI_API_KEY=xxx
#
# Release AAB (Play Store):
#   flutter build appbundle \
#     --dart-define=GEMINI_API_KEY=xxx \
#     --release
