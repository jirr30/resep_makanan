rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ────────────────────────────────────────────────────────────────
    match /users/{uid} {
      // Profil publik bisa dibaca siapa saja
      allow read: if true;

      // Pemilik akun bisa tulis semua field (untuk sync profil)
      // User lain hanya bisa update followerCount/followingCount (operasi follow)
      allow create: if request.auth != null && (
        request.auth.uid == uid ||
        request.resource.data.keys().hasOnly(['followerCount', 'followingCount'])
      );
      allow update: if request.auth != null && (
        request.auth.uid == uid ||
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['followerCount', 'followingCount'])
      );
    }

    // ── Follows ──────────────────────────────────────────────────────────────
    match /follows/{followId} {
      // Siapa saja yang login bisa baca (untuk cek isFollowing)
      allow read: if request.auth != null;

      // Hanya bisa buat follow milik sendiri:
      // document ID = "{myUid}_{targetUid}", followerId harus cocok
      allow create: if request.auth != null
        && followId.split('_')[0] == request.auth.uid
        && request.resource.data.followerId == request.auth.uid;

      // Hanya bisa hapus follow milik sendiri
      allow delete: if request.auth != null
        && followId.split('_')[0] == request.auth.uid;

      allow update: if false;
    }

    // ── Community Recipes ─────────────────────────────────────────────────────
    match /community_recipes/{recipeId} {
      allow read: if true;
      allow create: if request.auth != null;

      allow update: if request.auth != null && (
        // Penulis bisa update semua field (asalkan authorId tidak berubah)
        (resource.data.authorId == request.auth.uid
         && request.resource.data.authorId == resource.data.authorId)
        ||
        // User login lain hanya bisa update field interaksi
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['likes', 'averageRating', 'ratingCount', 'commentCount', 'viewCount'])
      );

      allow delete: if request.auth != null
        && resource.data.authorId == request.auth.uid;

      // ── Subcollection: komentar ─────────────────────────────────────────
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null
          && request.resource.data.userId == request.auth.uid;
        allow delete: if request.auth != null
          && resource.data.userId == request.auth.uid;
        allow update: if false;
      }

      // ── Subcollection: likes ────────────────────────────────────────────
      match /likes/{userId} {
        allow read: if true;
        allow write: if request.auth != null
          && request.auth.uid == userId;
      }

      // ── Subcollection: ratings ──────────────────────────────────────────
      match /ratings/{userId} {
        allow read: if true;
        allow write: if request.auth != null
          && request.auth.uid == userId;
      }
    }
  }
}
